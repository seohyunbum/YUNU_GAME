{
  "name": "ai-game-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "visual-check": "node scripts/visual-check.mjs",
    "visual:weapons": "node scripts/weapon-visual-preview.mjs",
    "perf-check": "node scripts/performance-smoke.mjs",
    "test:combat": "node scripts/combat-test.mjs",
    "test:save-migration": "node scripts/save-migration-test.mjs",
    "test:save-roundtrip": "node scripts/save-roundtrip-test.mjs",
    "test:save-repository": "node scripts/save-repository-test.mjs",
    "test:content": "node scripts/content-test.mjs",
    "test:systems": "node scripts/gameplay-systems-test.mjs",
    "test:balance": "node scripts/balance-test.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:size": "node scripts/check-main-size.mjs",
    "check:methods": "node scripts/check-method-count.mjs",
    "check:hotpath": "node scripts/check-hotpath-allocations.mjs",
    "verify": "npm run typecheck && npm run check:size && npm run check:methods && npm run check:architecture && npm run check:hotpath && npm run test:combat && npm run test:save-migration && npm run test:save-roundtrip && npm run test:save-repository && npm run test:content && npm run test:systems && npm run test:balance",
    "verify:full": "npm run verify && node scripts/check-server.mjs && npm run visual-check && npm run visual:weapons && npm run perf-check"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "playwright-core": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
